.container {
  padding: 30rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.clear-all-btn {
  font-size: 26rpx;
  color: #999;
  padding: 10rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
}

.history-item {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  margin-bottom: 30rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.delete-btn {
  font-size: 24rpx;
  color: #ff4d4f;
  background-color: #fff0f0;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-weight: bold;
}

.date {
  color: #999;
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.goal {
  color: #333;
  font-size: 30rpx;
  font-weight: bold;
}

.completed-tasks {
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 12rpx;
}

.task {
  font-size: 28rpx;
  color: #555;
  margin-bottom: 10rpx;
}

.task:last-child {
  margin-bottom: 0;
}

.dot {
  color: #07c160;
  margin-right: 10rpx;
  font-weight: bold;
}

.no-task {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 80rpx 0;
}