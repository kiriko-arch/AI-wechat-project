<view class="container">
  <!-- 顶部模型切换区域 -->
  <view class="model-selector">
    <view class="selector-label">当前模型：</view>
    <picker bindchange="onModelChange" value="{{modelIndex}}" range="{{models}}" range-key="name">
      <view class="picker-box">
        <text>{{models[modelIndex].name}}</text>
        <text class="arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 聊天记录区域 -->
  <scroll-view class="chat-area" scroll-y="true" scroll-into-view="{{scrollToMessage}}">
    <view class="message-list">
      <view 
        wx:for="{{messages}}" 
        wx:key="id" 
        id="msg-{{item.id}}"
        class="message-item {{item.role === 'user' ? 'user-message' : 'ai-message'}}"
      >
        <!-- 头像区域 -->
        <view class="avatar">
          <image wx:if="{{item.role === 'ai'}}" src="{{models[modelIndex].icon}}" class="avatar-img" mode="aspectFill"></image>
          <text wx:else>我</text>
        </view>
        <!-- 气泡区域 -->
        <view class="bubble">{{item.content}}</view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部输入区域 -->
  <view class="input-area">
    <input 
      class="chat-input" 
      placeholder="有什么问题想问 AI 呢？" 
      value="{{inputText}}"
      bindinput="onInput"
    />
    <view class="send-btn" bindtap="sendMessage">
      <text>发送</text>
    </view>
  </view>
</view>