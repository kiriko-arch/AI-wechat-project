/* --- 全局背景与布局 --- */
page {
  background-color: #F0FDF4;
}

.container {
  padding: 30rpx 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* --- 1. 顶部玻璃拟态个人信息卡 (Glassmorphism VIP Card) --- */
.vip-glass-card {
  position: relative;
  width: 100%;
  height: 240rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 16rpx 40rpx rgba(16, 185, 129, 0.08);
  overflow: hidden;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.vip-glow {
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: #34D399;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.3;
  z-index: 1;
}

.vip-content {
  position: relative;
  z-index: 2;
  width: 100%;
}

.vip-header {
  display: flex;
  align-items: center;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #10B981, #34D399);
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.4);
  margin-right: 32rpx;
}

.avatar-text {
  font-size: 36rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 2rpx;
}

.badge-wrapper {
  display: flex;
  flex-direction: column;
}

.badge-title {
  font-size: 44rpx;
  font-weight: 900;
  color: #111827;
  margin-bottom: 8rpx;
}

.badge-desc {
  font-size: 26rpx;
  color: #6B7280;
  font-weight: 500;
}

/* --- 2. 核心数据 Bento Grid --- */
.bento-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-template-rows: auto auto;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.bento-item {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 36rpx 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
  display: flex;
  align-items: center;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.bento-item:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
}

.bento-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: #ECFDF5;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.tasks-icon-box {
  background: #D1FAE5;
}

.bento-icon {
  font-size: 40rpx;
}

.bento-text-box {
  display: flex;
  flex-direction: column;
}

.bento-val {
  font-size: 44rpx;
  font-weight: 900;
  color: #111827;
  line-height: 1.1;
  margin-bottom: 4rpx;
}

.bento-label {
  font-size: 24rpx;
  color: #6B7280;
  font-weight: 500;
}

.bento-history {
  grid-column: span 2;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #111827; /* 深色强调卡片 */
  padding: 40rpx 48rpx;
}

.bento-history-content {
  display: flex;
  flex-direction: column;
}

.bento-history-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.bento-history-desc {
  font-size: 26rpx;
  color: #9CA3AF;
}

.bento-arrow {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  justify-content: center;
  align-items: center;
  color: #fff;
  font-size: 32rpx;
}

/* --- 3. 新版学习热力图 (Premium Aesthetic) --- */
.premium-heatmap-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.03), 0 2rpx 10rpx rgba(0, 0, 0, 0.02);
  border: 1px solid rgba(255,255,255,0.8);
}

.heatmap-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.heatmap-title {
  font-size: 38rpx;
  font-weight: 900;
  color: #111827;
  display: block;
}

.heatmap-subtitle {
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 6rpx;
  display: block;
  font-weight: 500;
}

.history-btn {
  display: flex;
  align-items: center;
  background: #F3F4F6;
  padding: 14rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #374151;
  font-weight: bold;
  transition: all 0.2s;
}

.history-btn:active {
  transform: scale(0.95);
  background: #E5E7EB;
}

.history-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  font-size: 24rpx;
  color: #9CA3AF;
  margin-bottom: 20rpx;
  font-weight: bold;
}

.heatmap-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 16rpx;
}

.heatmap-cell {
  aspect-ratio: 1; /* 保持正方形 */
  border-radius: 16rpx; /* 圆润的边角，看起来更高级 */
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  transition: all 0.3s ease;
  position: relative;
}

.empty-cell {
  background: transparent;
}

.inactive-cell {
  background: #F3F4F6;
  color: #D1D5DB;
}

.future-cell {
  background: transparent;
  color: #E5E7EB;
  border: 2rpx dashed #E5E7EB;
}

.active-cell {
  background: linear-gradient(135deg, #10B981, #059669); /* 翠绿渐变 */
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(16, 185, 129, 0.3);
  transform: scale(1.05); /* 轻微放大突出 */
}

.today-cell {
  border: 4rpx solid #111827;
}

/* 删除旧的历史记录入口样式 */

/* --- 往期回顾弹窗 --- */
.history-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(17, 24, 39, 0.4);
  backdrop-filter: blur(8px);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.history-modal-mask.show {
  visibility: visible;
  opacity: 1;
}

.history-modal-content {
  width: 100%;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 50rpx 40rpx 80rpx;
  box-sizing: border-box;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.history-modal-mask.show .history-modal-content.slide-up {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 50rpx;
  padding: 0 20rpx;
}

.current-month-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #111827;
}

.month-switch-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #374151;
  background: #F3F4F6;
  border-radius: 50%;
  font-weight: 300;
  transition: all 0.2s;
}

.month-switch-btn:active {
  background: #E5E7EB;
}

.month-switch-btn.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.modal-weekdays {
  color: #6B7280;
}

.modal-heatmap-grid {
  gap: 16rpx;
}

.close-btn-wrapper {
  margin-top: 60rpx;
  display: flex;
  justify-content: center;
}

.close-btn {
  background: #F3F4F6;
  color: #374151;
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx 0;
  width: 100%;
  text-align: center;
  border-radius: 24rpx;
}

.close-btn:active {
  background: #E5E7EB;
}